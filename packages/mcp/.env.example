# Required for every process (mock or live). Mock mode does not send it to Foundry;
# live mode uses it as the API bearer token.
FOUNDRY_API_TOKEN=your-token-or-local-dev-foundry-token-for-mock

# Mock vs live Foundry client only (not about whether the token is required).
FOUNDRY_USE_MOCK=1

# --- Streamable HTTP (MODE=http) only ---
PORT=3333
HOST=127.0.0.1

# Required when MODE=http. Clients send: Authorization: Bearer <same value>
MCP_HTTP_API_KEY=your-mcp-secret-or-local-dev-mcp-http-key

# Optional: comma-separated allowed Origin values
# ALLOWED_ORIGINS=http://127.0.0.1:6274,http://localhost:6274
