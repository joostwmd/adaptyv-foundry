# Copy to `.env` in this package (optional) or export in your shell.
# Inspector / `pnpm start:http` inherit the current environment.

# --- Foundry API (HTTP transport uses the same client as stdio) ---
# Mock data (no network): set one of 1, true, yes
FOUNDRY_USE_MOCK=1

# Live API: leave mock off and set a token
# FOUNDRY_USE_MOCK=0
# FOUNDRY_API_TOKEN=

# --- Streamable HTTP server (MODE=http) ---
PORT=3333
HOST=127.0.0.1

# If set, clients must send: Authorization: Bearer <same value>
# MCP_HTTP_API_KEY=

# Browser hardening: comma-separated allowed Origin values (optional)
# ALLOWED_ORIGINS=http://127.0.0.1:6274,http://localhost:6274
