{
  "name": "adaptyv-foundry-mcp",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "adaptyv-foundry-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "start": "node scripts/run-stdio-local.mjs",
    "start:http": "node scripts/run-http-local.mjs",
    "inspector": "pnpm run inspector:stdio",
    "inspector:stdio": "npx -y @modelcontextprotocol/inspector -e FOUNDRY_USE_MOCK=1 -e FOUNDRY_API_TOKEN=local-dev-foundry-token -- pnpm exec tsx src/index.ts",
    "inspector:stdio:live": "npx -y @modelcontextprotocol/inspector -e FOUNDRY_USE_MOCK=0 -e FOUNDRY_API_TOKEN=\"${FOUNDRY_API_TOKEN:?Set FOUNDRY_API_TOKEN for live Foundry API}\" -- pnpm exec tsx src/index.ts",
    "inspector:api": "pnpm run inspector:stdio:live",
    "inspector:http": "node scripts/dev-inspector-http.mjs",
    "inspector:http:connect": "node scripts/inspector-http-connect.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@adaptyv/foundry-shared": "workspace:*",
    "@adaptyv/foundry-sdk": "workspace:*",
    "@hono/node-server": "^1.13.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "hono": "^4.6.12",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
