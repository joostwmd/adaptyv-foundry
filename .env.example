# --- Foundry backend (SDK) ---
# In-memory mock API (shared mockdata). Values: 1, true, yes. Omit or 0/false for real API.
FOUNDRY_USE_MOCK=
# Required when FOUNDRY_USE_MOCK is off (server-side secret; never commit).
FOUNDRY_API_TOKEN=
FOUNDRY_API_BASE_URL=https://foundry-api-public.adaptyvbio.com/api/v1

# --- MCP HTTP server ---
MODE=stdio
PORT=3333
HOST=127.0.0.1
# If set, /mcp requires Authorization: Bearer <this value>. /health stays open. Empty = no Bearer gate (dev only).
MCP_HTTP_API_KEY=
# Comma-separated browser Origins allowed when Origin header is sent. Empty = do not block on Origin.
ALLOWED_ORIGINS=
